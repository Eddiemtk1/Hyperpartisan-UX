{
  "manifest_version": 3,
  "name": "TruthLens Bias Detector",
  "version": "1.0",
  "description": "Scans news articles for manipulative, hyperpartisan language using Llama-3.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage" 
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}